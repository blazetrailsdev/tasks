#!/usr/bin/env sh
# Pre-commit hook for blazetrailsdev/tasks.
#
# Must complete in <500ms on a warm working tree. Keep additions
# mtime-gated and incremental.

set -e

# 1. Regenerate the tracked generated artifacts BEFORE the prettier/lint gates
# so generated output is formatted, not rejected: each RFC README's `## Stories`
# table (from story frontmatter) and index.md (the human registry). Both are
# mtime-gated by js-yaml (it only re-parses files it reads) and complete well
# under 500ms on a warm tree. index.json / search.json are gitignored machine
# caches (rebuilt on demand) and don't need staging.
node scripts/stories-table.mjs >&2
node scripts/build-index.mjs >&2

# Prettier-format and stage whatever the regeneration touched (changed RFC
# READMEs + index.md), so the committed copy is canonical and reruns are no-ops.
# Generated-region edits are exempt from the README PR gate, same as index.md.
REGEN=$(git diff --name-only --diff-filter=ACM | grep -E '(^|/)README\.md$|^index\.md$' || true)
if [ -n "$REGEN" ]; then
  npx --no-install prettier --write $REGEN
  git add $REGEN
fi

# 2. Validate frontmatter and that no committed stories table is stale (now
# true, since we just regenerated). Run after regeneration so the commit that
# fixes drift isn't rejected by its own pre-fix state.
node scripts/validate.mjs >&2

# 3. Prettier-format and re-stage staged markdown (including the just-staged
# regenerated files), then markdownlint. We `--write` rather than `--check`:
# hand-authored stories (e.g. emphasis written as `*x*` where the config wants
# `_x_`) are auto-fixed at commit time instead of being rejected and left for
# the author to run `pnpm format` — which, when skipped or with husky uninstalled,
# lands unformatted files on main and reds the CI `format:check` for every PR.
# Mirrors the regen --write above; CI `prettier --check .` stays the backstop.
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  npx --no-install prettier --write $STAGED_MD
  git add $STAGED_MD
  npx --no-install markdownlint-cli2 $STAGED_MD || exit 1
fi
