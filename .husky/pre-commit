#!/usr/bin/env sh
# Pre-commit hook for blazetrailsdev/rfcs.
#
# Order matters — fail fast on the worst-case mistake (committed secret)
# before doing formatting work.
#
# Must complete in <500ms on a warm working tree. Keep additions
# mtime-gated and incremental.

set -e

# 1. Secret scan (staged changes only — fast).
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config .gitleaks.toml --no-banner
else
  echo "warning: gitleaks not installed — skipping secret scan." >&2
  echo "  install:  brew install gitleaks" >&2
fi

# 2. Prettier + markdownlint on staged markdown only.
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  npx --no-install prettier --check $STAGED_MD || {
    echo "prettier failed — run 'pnpm format' and re-stage." >&2
    exit 1
  }
  npx --no-install markdownlint-cli2 $STAGED_MD || exit 1
fi

# 3. Validate frontmatter and regenerate indices. Both are mtime-gated by
# js-yaml itself (it only re-parses files it reads); the whole step
# completes in well under 500ms on a warm tree because there are at most
# a few hundred markdown files in the repo.
node scripts/validate.mjs >&2
node scripts/build-index.mjs >&2
git add index.md index.json search.json
