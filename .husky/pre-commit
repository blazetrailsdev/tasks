#!/usr/bin/env sh
# Pre-commit hook for blazetrailsdev/tasks.
#
# Must complete in <500ms on a warm working tree. Keep additions
# mtime-gated and incremental.
#
# Install-independent setup
# -------------------------
# `core.hooksPath` points at this tracked `.husky/` directory (NOT husky v9's
# generated `.husky/_/` wrapper). The `prepare` script in package.json sets it
# on `pnpm install`, and the value lives in the shared common `.git/config`, so
# every worktree — including one created with a raw `git worktree add` and no
# `pnpm install` — resolves it to its own checked-out `.husky/` and runs this
# hook immediately. The old `.husky/_` indirection was untracked and absent in
# such worktrees, so git silently ran no hook and unformatted markdown reached
# main and reddened CI. These scripts are plain `sh` (no husky sourcing line),
# so they are directly runnable as a hooksPath target.

set -e

# Fail closed: these gates need `node` plus the devDependencies (js-yaml,
# prettier, markdownlint-cli2). If the tooling is absent the commit MUST be
# blocked with an actionable message, never silently skipped. `npx --no-install`
# already exits non-zero when a binary is missing; the checks below surface a
# clear error before any work runs.
if ! command -v node > /dev/null 2>&1; then
  echo "pre-commit: \`node\` not found on PATH — cannot run the format/lint gate." >&2
  echo "Install Node and run \`pnpm install\`, then retry the commit." >&2
  exit 1
fi
if [ ! -d node_modules ]; then
  echo "pre-commit: node_modules is missing — the prettier/markdownlint gate cannot run." >&2
  echo "Run \`pnpm install\` in this worktree, then retry the commit." >&2
  exit 1
fi

# 1. Regenerate the tracked generated artifact BEFORE the prettier/lint gates
# so generated output is formatted, not rejected: index.md (the human registry).
# It is mtime-gated by js-yaml (it only re-parses files it reads) and completes
# well under 500ms on a warm tree. index.json / search.json are gitignored
# machine caches (rebuilt on demand) and don't need staging.
node scripts/build-index.mjs >&2

# Prettier-format and stage whatever the regeneration touched (index.md), so the
# committed copy is canonical and reruns are no-ops. index.md edits are exempt
# from the README PR gate.
REGEN=$(git diff --name-only --diff-filter=ACM | grep -E '^index\.md$' || true)
if [ -n "$REGEN" ]; then
  npx --no-install prettier --write $REGEN
  git add $REGEN
fi

# 2. Validate frontmatter.
node scripts/validate.mjs >&2

# 3. Prettier-format and re-stage staged markdown (including the just-staged
# regenerated files), then markdownlint. We `--write` rather than `--check`:
# hand-authored stories (e.g. emphasis written as `*x*` where the config wants
# `_x_`) are auto-fixed at commit time instead of being rejected and left for
# the author to run `pnpm format` — which, when skipped or with husky uninstalled,
# lands unformatted files on main and reds the CI `format:check` for every PR.
# Mirrors the regen --write above; CI `prettier --check .` stays the backstop.
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  npx --no-install prettier --write $STAGED_MD
  git add $STAGED_MD
  npx --no-install markdownlint-cli2 $STAGED_MD || exit 1
fi
